{
    "compilerOptions": {
        "outDir": "./dist/",
        "target": "ES2024",
        "jsx": "react",
        "module": "ESNext",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "allowJs": true,
        "checkJs": true,
        "alwaysStrict": true,
        "experimentalDecorators": true,
        "exactOptionalPropertyTypes": true,
        "strictNullChecks": true,
        "moduleResolution": "bundler",
        "removeComments": false,
        "noImplicitAny": true,
        "preserveConstEnums": false,
        "sourceMap": true,
        "skipLibCheck": true,
        "pretty": false,
        "lib": ["esnext", "dom", "dom.iterable"],
        "types": ["node", "jest", "@types/jquery", "@types/tampermonkey"]
    },
    "include": ["**/*"],
    "exclude": ["dist", "node_modules", "coverage", "**/*.spec.ts", "**/*.config.mjs"]
}
