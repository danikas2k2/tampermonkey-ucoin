{
    "name": "ucoin",
    "version": "1.15.9",
    "description": "",
    "main": "index.js",
    "directories": {
        "src/lib": "src/lib"
    },
    "scripts": {
        "build": "vite build",
        "watch": "vite build --watch",
        "preversion": "git pull && pnpm test",
        "version": "pnpm run build && git add --all",
        "postversion": "git push && git push --tags",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "update-deps": "syncpack update && pnpm install"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/danikas2k2/tampermonkey-ucoin.git"
    },
    "browser": [
        "last 1 version",
        "> 1%",
        "not dead"
    ],
    "keywords": [],
    "author": "",
    "license": "ISC",
    "homepage": "https://github.com/danikas2k2/tampermonkey-ucoin",
    "dependencies": {
        "classnames": "^2.5.1",
        "moment": "^2.30.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/core-js": "^2.5.8",
        "@types/jest": "^30.0.0",
        "@types/jquery": "^4.0.0",
        "@types/md5": "^2.3.6",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/tampermonkey": "^5.0.5",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-functional": "^9.0.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "jest": "^30.3.0",
        "jest-chain": "^1.1.6",
        "jest-environment-jsdom": "^30.3.0",
        "jest-expect-message": "^1.1.3",
        "jest-extended": "^7.0.0",
        "jest-to-match-shape-of": "^1.3.2",
        "less": "^4.6.4",
        "prettier": "^3.8.2",
        "stylelint": "^17.7.0",
        "stylelint-config-recommended": "^18.0.0",
        "terser": "^5.46.1",
        "ts-jest": "^29.4.9",
        "ts-node": "^10.9.2",
        "tslint-config-prettier": "^1.18.0",
        "typed-css-modules": "^0.9.1",
        "typescript": "^6.0.2",
        "vite": "^8.0.8",
        "vite-plugin-css-injected-by-js": "^4.0.1",
        "vite-plugin-monkey": "^7.1.9"
    },
    "prettier": {
        "singleQuote": true,
        "tabWidth": 4,
        "printWidth": 100,
        "trailingComma": "es5"
    },
    "jest": {
        "verbose": true,
        "moduleFileExtensions": [
            "js",
            "ts",
            "tsx"
        ],
        "transform": {
            "\\.[jt]sx?$": "ts-jest"
        },
        "setupFilesAfterEnv": [
            "<rootDir>/jest.setup.ts"
        ],
        "preset": "ts-jest",
        "testEnvironment": "jsdom",
        "collectCoverage": false,
        "collectCoverageFrom": [
            "src/**/*.{ts,tsx}",
            "!src/**/*.d.ts",
            "!src/data/**/*.ts"
        ]
    },
    "pnpm": {
        "overrides": {
            "glob": "^11.0.0",
            "micromatch": "^4.0.8",
            "minimatch": "^10.2.4",
            "postcss": "^8.5.8",
            "sugarss": "^5.0.1"
        },
        "peerDependencyRules": {
            "allowedVersions": {
                "eslint": "10"
            }
        }
    },
    "syncpack": {
        "indent": "    "
    }
}
